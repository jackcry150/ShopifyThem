{% doc %}
  @prompt
    Create a full-width product information section using horizontal tabs (not accordion/collapsible blocks).
    
    Requirements:
    
    Layout:
    
    * Display tabs horizontally at the top of the section.
    * The section width should match the product page content width (Page Width).
    * Tabs should be aligned left.
    * Show a thin underline below the active tab.
    * Use a clean, minimal style similar to premium collectible, designer toy, and BJD doll websites.
    
    Tabs:
    
    1. Product Details
    2. Product Photos
    3. Pre-Order Information
    4. Shipping Information
    5. Return & Refund Policy
    6. Reviews
    7. Join Our Community
    
    Interaction:
    
    * When a customer clicks a tab, only the corresponding content is displayed.
    * Hide all other tab content.
    * No page reload.
    * Smooth fade transition between tabs.
    * The first tab (Product Details) should be active by default.
    
    Content Area:
    
    * Display content directly below the tabs.
    * Support rich text, images, videos, links, and metafields.
    * Allow each tab to have independent content.
    * Support dynamic content from Shopify product metafields.
    
    Design:
    
    * Full page width container.
    * Maximum content width: 1200px–1400px.
    * Mobile responsive.
    * Tabs become horizontally scrollable on mobile.
    * Background remains transparent.
    * Border line under tab navigation.
    * Typography consistent with premium lifestyle and collectible brands.
    
    Admin Settings:
    
    * Allow merchants to rename tabs.
    * Allow merchants to reorder tabs.
    * Allow merchants to enable/disable tabs.
    * Allow content editing for each tab directly from Theme Editor.
    
    Example User Experience:
    
    Click "Product Details" → Show product description.
    
    Click "Pre-Order Information" → Show production timeline and preorder policies.
    
    Click "Shipping Information" → Show shipping times and delivery details.
    
    Click "Return & Refund Policy" → Show refund rules.
    
    Click "Reviews" → Show Shopify review app block.
    
    Click "Join Our Community" → Show Discord, Facebook and Instagram links.
    
    Only one tab content should be visible at a time.
    
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-product-tabs-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background: transparent;
    margin: 40px 0;
  }

  .ai-product-tabs-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_content_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-product-tabs-nav-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 0;
    border-bottom: 1px solid {{ block.settings.border_color }};
    overflow-x: auto;
    overflow-y: hidden;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    margin-bottom: 32px;
  }

  .ai-product-tabs-nav-{{ ai_gen_id }}::-webkit-scrollbar {
    display: none;
  }

  .ai-product-tabs-button-{{ ai_gen_id }} {
    background: none;
    border: none;
    padding: 16px 24px;
    font-size: {{ block.settings.tab_font_size }}px;
    font-weight: {{ block.settings.tab_font_weight }};
    color: {{ block.settings.tab_text_color }};
    cursor: pointer;
    white-space: nowrap;
    position: relative;
    transition: color 0.3s ease;
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
    letter-spacing: {{ block.settings.tab_letter_spacing }};
  }

  .ai-product-tabs-button-{{ ai_gen_id }}:hover {
    color: {{ block.settings.tab_hover_color }};
  }

  .ai-product-tabs-button-{{ ai_gen_id }}.active {
    color: {{ block.settings.tab_active_color }};
    border-bottom-color: {{ block.settings.tab_active_underline_color }};
  }

  .ai-product-tabs-content-{{ ai_gen_id }} {
    position: relative;
    min-height: 200px;
  }

  .ai-product-tabs-panel-{{ ai_gen_id }} {
    display: none;
    opacity: 0;
    transition: opacity {{ block.settings.transition_duration }}s ease;
  }

  .ai-product-tabs-panel-{{ ai_gen_id }}.active {
    display: block;
    opacity: 1;
  }

  .ai-product-tabs-panel-content-{{ ai_gen_id }} {
    font-size: {{ block.settings.content_font_size }}px;
    line-height: {{ block.settings.content_line_height }};
    color: {{ block.settings.content_text_color }};
  }

  .ai-product-tabs-panel-content-{{ ai_gen_id }} h1,
  .ai-product-tabs-panel-content-{{ ai_gen_id }} h2,
  .ai-product-tabs-panel-content-{{ ai_gen_id }} h3,
  .ai-product-tabs-panel-content-{{ ai_gen_id }} h4,
  .ai-product-tabs-panel-content-{{ ai_gen_id }} h5,
  .ai-product-tabs-panel-content-{{ ai_gen_id }} h6 {
    margin-top: 0;
    margin-bottom: 16px;
  }

  .ai-product-tabs-panel-content-{{ ai_gen_id }} p {
    margin-bottom: 16px;
  }

  .ai-product-tabs-panel-content-{{ ai_gen_id }} img {
    max-width: 100%;
    height: auto;
    display: block;
    margin: 20px 0;
  }

  .ai-product-tabs-panel-content-{{ ai_gen_id }} ul,
  .ai-product-tabs-panel-content-{{ ai_gen_id }} ol {
    margin-bottom: 16px;
    padding-left: 24px;
  }

  .ai-product-tabs-panel-content-{{ ai_gen_id }} a {
    color: {{ block.settings.link_color }};
    text-decoration: underline;
  }

  .ai-product-tabs-panel-content-{{ ai_gen_id }} a:hover {
    color: {{ block.settings.link_hover_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-product-tabs-button-{{ ai_gen_id }} {
      padding: 12px 16px;
      font-size: {{ block.settings.tab_font_size | times: 0.9 }}px;
    }

    .ai-product-tabs-container-{{ ai_gen_id }} {
      padding: 0 16px;
    }

    .ai-product-tabs-nav-{{ ai_gen_id }} {
      margin-bottom: 24px;
    }

    .ai-product-tabs-panel-content-{{ ai_gen_id }} {
      font-size: {{ block.settings.content_font_size | times: 0.95 }}px;
    }
  }
{% endstyle %}

<product-tabs-{{ ai_gen_id }} class="ai-product-tabs-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
