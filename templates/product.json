        "collapsible_row_UNiDah": {
          "type": "collapsible_row",
          "settings": {
            "heading": "CanI return a product if it has quality issues?",
            "icon": "question_mark",
            "row_content": "<p>For any product with quality issues, such as damage or defects, please contact our after-sales team and provide photos or videos.<br/><br/>Note:For dolls and blind box items, please provide a clear unboxing video, as it is required for us to process the issue.<br/><br/>If a quality issue is confirmed, we will process a return and refund, and cover the return shipping cost.<br/><br/>!!! Please note that slight imperfections may occur due to handmade production and are not considered quality issues. recommend that customers carefully consider this before placing an order.</p>",
            "page": ""
          }
        },
        "collapsible_row_LNwzMC": {
          "type": "collapsible_row",
          "settings": {
            "heading": "What should I know before ordering?",
            "icon": "question_mark",
            "row_content": "<p>Please check the product status before purchasing.<br/><br/>• Pre-Order items require a production period of approximately 30–60 days before shipping.<br/>• In Stock items are usually shipped within 10 days after payment.<br/>• For Pre-Order purchases, please provide a valid email address so we can send shipping and tracking updates once your order is on its way.<br/>• Join our Discord and Facebook communities to stay updated on production progress, upcoming releases, and community discussions.<br/></p>",
            "page": ""
