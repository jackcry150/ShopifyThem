        "collapsible_row_rRMpyz": {
          "type": "collapsible_row",
          "settings": {
            "heading": "How can I cancel my order?",
            "icon": "question_mark",
            "row_content": "<p>To cancel your order, please contact us. If the order has not been shipped, we can process the cancellation for you. Once the order has been shipped, cancellation is no longer possible. However, after receiving your package, you can contact us to arrange a return or exchange at contact@goomooplay.com</p>",
            "page": ""
