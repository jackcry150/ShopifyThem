{{ 'section-wholesale-contact.css' | asset_url | stylesheet_tag }}
{{ 'section-contact-form.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="wholesale page-width page-width--narrow section-{{ section.id }}-padding">
    <h1 class="wholesale__heading {{ section.settings.heading_size }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
      {{ section.settings.heading }}
    </h1>

    <div class="wholesale__content{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
      <p class="wholesale__intro">{{ section.settings.intro_text }}</p>
      <div class="wholesale__body rte">
        {{ section.settings.section1_body }}
      </div>
    </div>

    <hr class="wholesale__divider">

    <p class="wholesale__form-heading{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
      {{ section.settings.form_heading }}
    </p>

    {%- liquid
      assign contact_form_class = 'isolate'
      if settings.animations_reveal_on_scroll
        assign contact_form_class = 'isolate scroll-trigger animate--slide-in'
      endif
    -%}
    {%- form 'contact', id: 'InfluencerForm', class: contact_form_class -%}
      {%- if form.posted_successfully? -%}
        <h2 class="form-status form-status-list form__message" tabindex="-1" autofocus>
          {{- 'icon-success.svg' | inline_asset_content -}}
          {{ 'templates.contact.form.post_success' | t }}
        </h2>
      {%- elsif form.errors -%}
        <div class="form__message">
          <h2 class="form-status caption-large text-body" role="alert" tabindex="-1" autofocus>
            {{- 'icon-error.svg' | inline_asset_content -}}
            {{ 'templates.contact.form.error_heading' | t }}
          </h2>
        </div>
        <ul class="form-status-list caption-large" role="list">
          <li>
            <a href="#ContactForm-email" class="link">
              {{ form.errors.translated_fields.email | capitalize }}
              {{ form.errors.messages.email }}
            </a>
          </li>
        </ul>
      {%- endif -%}
      <div class="field">
        <input
          class="field__input"
          autocomplete="name"
          type="text"
          id="ContactForm-name"
          name="contact[{{ 'templates.contact.form.name' | t }}]"
          value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}"
          placeholder="{{ 'templates.contact.form.name' | t }}"
          required
        >
        <label class="field__label" for="ContactForm-name">
          {{- 'templates.contact.form.name' | t }}
          <span aria-hidden="true">*</span>
        </label>
      </div>
      <div class="field field--with-error">
        <input
          autocomplete="email"
          type="email"
          id="ContactForm-email"
          class="field__input"
          name="contact[email]"
          spellcheck="false"
          autocapitalize="off"
          value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
          aria-required="true"
          required
          {% if form.errors contains 'email' %}
            aria-invalid="true"
            aria-describedby="ContactForm-email-error"
          {% endif %}
          placeholder="{{ 'templates.contact.form.email' | t }}"
        >
        <label class="field__label" for="ContactForm-email">
          {{- 'templates.contact.form.email' | t }}
          <span aria-hidden="true">*</span>
        </label>
        {%- if form.errors contains 'email' -%}
          <small class="contact__field-error" id="ContactForm-email-error">
            <span class="visually-hidden">{{ 'accessibility.error' | t }}</span>
            <span class="form__message">
              <span class="svg-wrapper">{{- 'icon-error.svg' | inline_asset_content -}}</span>
              {{- form.errors.translated_fields.email | capitalize }}
              {{ form.errors.messages.email -}}
            </span>
          </small>
        {%- endif -%}
      </div>
      <div class="field">
        <input
          class="field__input"
          type="text"
          id="ContactForm-country"
          name="contact[{{ 'templates.influencer.form.country' | t }}]"
          placeholder="{{ 'templates.influencer.form.country' | t }}"
          required
        >
        <label class="field__label" for="ContactForm-country">
          {{- 'templates.influencer.form.country' | t }}
          <span aria-hidden="true">*</span>
        </label>
      </div>
      <div class="field">
        <textarea
          rows="5"
          id="ContactForm-info"
          class="text-area field__input"
          name="contact[{{ 'templates.influencer.form.further_info' | t }}]"
          placeholder="{{ 'templates.influencer.form.further_info' | t }}"
        >
          {{- form.further_info -}}
        </textarea>
        <label class="form__label field__label" for="ContactForm-info">{{ 'templates.influencer.form.further_info' | t }}</label>
      </div>
      <fieldset class="wholesale__radio-group">
        <legend class="wholesale__radio-legend">{{ 'templates.influencer.form.ever_purchased' | t }}</legend>
        <label class="wholesale__radio">
          <input type="radio" name="contact[{{ 'templates.influencer.form.ever_purchased' | t }}]" value="Yes">
          <span>{{ 'templates.wholesale.form.yes' | t }}</span>
        </label>
        <label class="wholesale__radio">
          <input type="radio" name="contact[{{ 'templates.influencer.form.ever_purchased' | t }}]" value="No">
          <span>{{ 'templates.wholesale.form.no' | t }}</span>
        </label>
      </fieldset>
      <div class="field">
        <input
          class="field__input"
          type="text"
          id="ContactForm-similar"
          name="contact[{{ 'templates.influencer.form.similar_stores' | t }}]"
          placeholder="{{ 'templates.influencer.form.similar_stores' | t }}"
        >
        <label class="field__label" for="ContactForm-similar">{{ 'templates.influencer.form.similar_stores' | t }}</label>
      </div>
      <div class="field">
        <input
          class="field__input"
          type="url"
          id="ContactForm-unbox"
          name="contact[{{ 'templates.influencer.form.unbox_video' | t }}]"
          placeholder="{{ 'templates.influencer.form.unbox_video' | t }}"
        >
        <label class="field__label" for="ContactForm-unbox">{{ 'templates.influencer.form.unbox_video' | t }}</label>
      </div>
      <div class="field">
        <input
          class="field__input"
          type="text"
          id="ContactForm-instagram"
          name="contact[{{ 'templates.influencer.form.instagram' | t }}]"
          placeholder="@"
        >
        <label class="field__label" for="ContactForm-instagram">{{ 'templates.influencer.form.instagram' | t }}</label>
      </div>
      <div class="field">
        <input
          class="field__input"
          type="text"
          id="ContactForm-youtube"
          name="contact[{{ 'templates.influencer.form.youtube' | t }}]"
          placeholder="@"
        >
        <label class="field__label" for="ContactForm-youtube">{{ 'templates.influencer.form.youtube' | t }}</label>
      </div>
      <div class="field">
        <input
          class="field__input"
          type="text"
          id="ContactForm-tiktok"
          name="contact[{{ 'templates.influencer.form.tiktok' | t }}]"
          placeholder="@"
        >
        <label class="field__label" for="ContactForm-tiktok">{{ 'templates.influencer.form.tiktok' | t }}</label>
      </div>
      <div class="field">
        <input
          class="field__input"
          type="text"
          id="ContactForm-other-media"
          name="contact[{{ 'templates.influencer.form.other_media' | t }}]"
          placeholder="{{ 'templates.influencer.form.other_media' | t }}"
        >
        <label class="field__label" for="ContactForm-other-media">{{ 'templates.influencer.form.other_media' | t }}</label>
      </div>
      <div class="field">
        <textarea
          rows="5"
          id="ContactForm-channel"
          class="text-area field__input"
          name="contact[{{ 'templates.influencer.form.channel' | t }}]"
          placeholder="{{ 'templates.influencer.form.channel' | t }}"
        >
          {{- form.channel -}}
        </textarea>
        <label class="form__label field__label" for="ContactForm-channel">{{ 'templates.influencer.form.channel' | t }}</label>
      </div>
      <div class="contact__button">
        <button type="submit" class="button">
          {{ 'templates.contact.form.send' | t }}
        </button>
      </div>
      <p class="wholesale__required-note">{{ 'templates.contact.form.required_note' | t }}</p>
    {%- endform -%}

    <p class="wholesale__captcha-notice">{{ 'templates.contact.form.captcha_notice' | t }}</p>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.influencer-cooperation.name",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.influencer-cooperation.settings.heading.label",
      "default": "Influencer Cooperation"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h2", "label": "t:sections.all.heading_size.options__1.label" },
        { "value": "h1", "label": "t:sections.all.heading_size.options__2.label" },
        { "value": "h0", "label": "t:sections.all.heading_size.options__3.label" }
      ],
      "default": "h1",
      "label": "t:sections.all.heading_size.label"
    },
    {
      "type": "textarea",
      "id": "intro_text",
      "label": "t:sections.influencer-cooperation.settings.intro_text.label",
      "default": "We welcome creators from YouTube, Instagram, TikTok, Twitter and more to collaborate with us. Whether you are an experienced content creator or just starting your journey as a toy influencer, we would love to hear from you."
    },
    {
      "type": "richtext",
      "id": "section1_body",
      "label": "t:sections.influencer-cooperation.settings.body_text.label",
      "default": "<h3>You're a toy content creator now.</h3><p>If you already create toy-related content, we value your expertise and unique insights. Reach out and let's explore what we can do together.</p><h3>You want to be a toy content creator.</h3><p>If you're aspiring to become a toy influencer, we offer tailored cooperation plans to help you get started. Contact us and let's explore the opportunities.</p><p>Fill in the form below, and let's bring more happiness and surprises to toy lovers together.</p>"
    },
    {
      "type": "text",
      "id": "form_heading",
      "label": "t:sections.influencer-cooperation.settings.form_heading.label",
      "default": "Influencer Contact Form"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "t:sections.influencer-cooperation.presets.name"
    }
  ]
}
{% endschema %}
