{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-article-card.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign source_blog = blogs[section.settings.blog_handle]
  assign articles_to_show = section.settings.articles_to_show
-%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  #shopify-section-{{ section.id }} {
    background: #ffffff;
    color: #111111;
  }

  .more-guides-hub-{{ section.id }} {
    background: #fff;
    color: #111111;
  }

  .more-guides-hub-{{ section.id }} .more-guides-hub__hero {
    max-width: 82rem;
    margin: 0 auto 4rem;
    text-align: center;
  }

  .more-guides-hub-{{ section.id }} .more-guides-hub__eyebrow {
    margin: 0 0 1rem;
    color: rgba(var(--color-foreground), 0.58);
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .more-guides-hub-{{ section.id }} .more-guides-hub__heading {
    margin: 0;
    font-size: clamp(3.2rem, 5vw, 6.4rem);
    line-height: 1.02;
    letter-spacing: -0.04em;
  }

  .more-guides-hub-{{ section.id }} .more-guides-hub__intro {
    max-width: 64rem;
    margin: 1.8rem auto 0;
    color: rgba(var(--color-foreground), 0.68);
    font-size: 1.6rem;
    line-height: 1.65;
  }

  .more-guides-hub-{{ section.id }} .more-guides-hub__topics {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1.2rem;
    margin: 0 0 4.8rem;
  }

  .more-guides-hub-{{ section.id }} .more-guides-hub__topic {
    padding: 1.8rem;
    border: 0.1rem solid rgba(var(--color-foreground), 0.1);
    border-radius: 1.2rem;
    background: rgba(var(--color-foreground), 0.025);
  }

  .more-guides-hub-{{ section.id }} .more-guides-hub__topic-title {
    display: block;
    margin-bottom: 0.6rem;
    font-size: 1.5rem;
    font-weight: 800;
  }

  .more-guides-hub-{{ section.id }} .more-guides-hub__topic-text {
    margin: 0;
    color: rgba(var(--color-foreground), 0.62);
    font-size: 1.3rem;
    line-height: 1.45;
  }

  .more-guides-hub-{{ section.id }} .more-guides-hub__section-header {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 2rem;
    margin-bottom: 2.4rem;
    border-bottom: 0.1rem solid rgba(var(--color-foreground), 0.1);
    padding-bottom: 1.4rem;
  }

  .more-guides-hub-{{ section.id }} .more-guides-hub__section-title {
    margin: 0;
    font-size: clamp(2.4rem, 3vw, 3.6rem);
    letter-spacing: -0.03em;
  }

  .more-guides-hub-{{ section.id }} .more-guides-hub__blog-link {
    color: rgb(var(--color-foreground));
    font-size: 1.4rem;
    font-weight: 700;
    text-underline-offset: 0.3rem;
    white-space: nowrap;
  }

  .more-guides-hub-{{ section.id }} .more-guides-hub__articles {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 2.4rem;
  }

  .more-guides-hub-{{ section.id }} .more-guides-hub__empty {
    margin: 0;
    padding: 2rem;
    border: 0.1rem dashed rgba(var(--color-foreground), 0.18);
    border-radius: 1rem;
    color: rgba(var(--color-foreground), 0.64);
    text-align: center;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  @media screen and (max-width: 989px) {
    .more-guides-hub-{{ section.id }} .more-guides-hub__topics,
    .more-guides-hub-{{ section.id }} .more-guides-hub__articles {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media screen and (max-width: 749px) {
    .more-guides-hub-{{ section.id }} .more-guides-hub__hero {
      text-align: left;
    }

    .more-guides-hub-{{ section.id }} .more-guides-hub__topics,
    .more-guides-hub-{{ section.id }} .more-guides-hub__articles {
      grid-template-columns: 1fr;
    }

    .more-guides-hub-{{ section.id }} .more-guides-hub__section-header {
      display: block;
    }

    .more-guides-hub-{{ section.id }} .more-guides-hub__blog-link {
      display: inline-block;
      margin-top: 1rem;
    }
  }
{%- endstyle -%}

<section class="more-guides-hub more-guides-hub-{{ section.id }} section-{{ section.id }}-padding">
  <div class="page-width">
    <div class="more-guides-hub__hero">
      {%- if section.settings.eyebrow != blank -%}
        <p class="more-guides-hub__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      <h1 class="more-guides-hub__heading">{{ section.settings.heading }}</h1>
      {%- if section.settings.intro != blank -%}
        <div class="more-guides-hub__intro rte">
          {{ section.settings.intro }}
        </div>
      {%- endif -%}
    </div>

    <div class="more-guides-hub__topics" aria-label="Guide topics">
      {%- for block in section.blocks -%}
        <div class="more-guides-hub__topic" {{ block.shopify_attributes }}>
          <span class="more-guides-hub__topic-title">{{ block.settings.title }}</span>
          {%- if block.settings.text != blank -%}
            <p class="more-guides-hub__topic-text">{{ block.settings.text }}</p>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>

    <div class="more-guides-hub__section-header">
      <h2 class="more-guides-hub__section-title">{{ section.settings.articles_heading }}</h2>
      {%- if source_blog != blank -%}
        <a class="more-guides-hub__blog-link" href="{{ source_blog.url }}">View all guides</a>
      {%- endif -%}
    </div>

    {%- if source_blog != blank and source_blog.articles_count > 0 -%}
      <div class="more-guides-hub__articles">
        {%- for article in source_blog.articles limit: articles_to_show -%}
          <div class="more-guides-hub__article">
            {%- render 'article-card',
              blog: source_blog,
              article: article,
              media_height: 'medium',
              media_aspect_ratio: article.image.aspect_ratio,
              show_image: section.settings.show_images,
              show_date: section.settings.show_date,
              show_author: false,
              show_excerpt: true
            -%}
          </div>
        {%- endfor -%}
      </div>
    {%- else -%}
      <p class="more-guides-hub__empty">
        No published guides yet. Publish reviewed GEOFlow articles in the {{ section.settings.blog_handle | escape }} blog and they will appear here.
      </p>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "More Guides hub",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "blog_handle",
      "label": "Blog handle",
      "default": "guides"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "GooMoo Play Guides"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "More Guides"
    },
    {
      "type": "richtext",
      "id": "intro",
      "label": "Intro text",
      "default": "<p>Browse practical doll outfit, collectible, pre-order, shipping and care guides. Reviewed GEOFlow articles published in the Guides blog will appear here automatically.</p>"
    },
    {
      "type": "text",
      "id": "articles_heading",
      "label": "Articles heading",
      "default": "Latest Guides"
    },
    {
      "type": "range",
      "id": "articles_to_show",
      "label": "Articles to show",
      "min": 3,
      "max": 12,
      "step": 1,
      "default": 9
    },
    {
      "type": "checkbox",
      "id": "show_images",
      "label": "Show article images",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_date",
      "label": "Show publish date",
      "default": true
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 56
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 72
    }
  ],
  "blocks": [
    {
      "type": "topic",
      "name": "Topic",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Doll Outfit Guides"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Sizing, styling and compatibility notes for collectible dolls."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "More Guides hub",
      "blocks": [
        {
          "type": "topic",
          "settings": {
            "title": "Doll Outfit Guides",
            "text": "Sizing, styling and compatibility notes for collectible dolls."
          }
        },
        {
          "type": "topic",
          "settings": {
            "title": "Action Figure Guides",
            "text": "Accessory, scale and display ideas for 1/12 action figures."
          }
        },
        {
          "type": "topic",
          "settings": {
            "title": "Pre-order & Shipping Notes",
            "text": "Clear answers about preorder timing, delivery and order expectations."
          }
        },
        {
          "type": "topic",
          "settings": {
            "title": "Collectible Care",
            "text": "Care, storage and handling advice for outfits and figures."
          }
        }
      ]
    }
  ]
}
{% endschema %}
