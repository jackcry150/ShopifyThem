{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'category-collection-tabs.css' | asset_url | stylesheet_tag }}
<script src="{{ 'category-collection-tabs.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign first_block = section.blocks.first
  assign desktop_columns = section.settings.products_to_show | at_most: 4
  assign preorder_tag = section.settings.preorder_tag | default: 'Pre-order' | strip
  assign normalized_preorder_tag = preorder_tag | downcase
  assign compact_preorder_tag = normalized_preorder_tag | replace: '-', '' | replace: '_', '' | replace: ' ', ''
  assign preorder_badge_label = section.settings.preorder_badge_label | default: 'Pre-order' | strip
  assign first_label = first_block.settings.label
  if first_label == blank and first_block.settings.collection != blank
    assign first_label = first_block.settings.collection.title
  endif
  if first_label == blank
    assign first_label = 'Category'
  endif
-%}

<category-collection-tabs
  class="category-collection-tabs"
  style="
    --category-tabs-background: {{ section.settings.background_color }};
    --category-tabs-text: {{ section.settings.text_color }};
    --category-tabs-heading: {{ section.settings.heading_color }};
    --category-tabs-card: {{ section.settings.card_color }};
    --category-tabs-padding-top: {{ section.settings.padding_top }}px;
    --category-tabs-padding-bottom: {{ section.settings.padding_bottom }}px;
    --category-tabs-desktop-columns: {{ desktop_columns }};
  "
>
  {%- if section.blocks.size > 0 -%}
    <div class="category-collection-tabs__navigation">
      <div class="page-width">
        <div
          class="category-collection-tabs__tablist"
          role="tablist"
          aria-label="{{ section.settings.heading | default: 'Collections' | strip_html | escape }}"
        >
          {%- for block in section.blocks -%}
            {%- liquid
              assign category_label = block.settings.label
              if category_label == blank and block.settings.collection != blank
                assign category_label = block.settings.collection.title
              endif
              if category_label == blank
                assign category_label = 'Category'
              endif
            -%}
            {%- if block.settings.collection != blank -%}
              <a
                id="CategoryTab-{{ section.id }}-{{ block.id }}"
                class="category-collection-tabs__tab{% if block.id == first_block.id %} is-active{% endif %}"
                href="{{ block.settings.collection.url }}"
                role="tab"
                aria-selected="{% if block.id == first_block.id %}true{% else %}false{% endif %}"
                aria-controls="CategoryPanel-{{ section.id }}-{{ block.id }}"
                tabindex="{% if block.id == first_block.id %}0{% else %}-1{% endif %}"
                data-block-id="{{ block.id }}"
                {{ block.shopify_attributes }}
              >
                {{ category_label | escape }}
              </a>
            {%- else -%}
              <button
                id="CategoryTab-{{ section.id }}-{{ block.id }}"
                class="category-collection-tabs__tab{% if block.id == first_block.id %} is-active{% endif %}"
                type="button"
                role="tab"
                aria-selected="{% if block.id == first_block.id %}true{% else %}false{% endif %}"
                aria-controls="CategoryPanel-{{ section.id }}-{{ block.id }}"
                tabindex="{% if block.id == first_block.id %}0{% else %}-1{% endif %}"
                data-block-id="{{ block.id }}"
                {{ block.shopify_attributes }}
              >
                {{ category_label | escape }}
              </button>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    </div>

    <div class="category-collection-tabs__content">
      <div class="category-collection-tabs__content-inner page-width">
        <h2 class="category-collection-tabs__active-heading" data-active-heading aria-live="polite">
          {{ first_label | escape }}
        </h2>

        <div class="category-collection-tabs__panels">
          {%- assign skip_card_product_styles = false -%}
          {%- for block in section.blocks -%}
            <div
              id="CategoryPanel-{{ section.id }}-{{ block.id }}"
              class="category-collection-tabs__panel{% if block.id == first_block.id %} is-active{% endif %}"
              role="tabpanel"
              aria-labelledby="CategoryTab-{{ section.id }}-{{ block.id }}"
              tabindex="0"
              {% unless block.id == first_block.id %}hidden{% endunless %}
            >
              {%- capture preorder_product_cards -%}
                {%- assign preorder_products_shown = 0 -%}
                {%- if block.settings.collection != blank -%}
                  {%- for product in block.settings.collection.products -%}
                    {%- if preorder_products_shown >= section.settings.products_to_show -%}
                      {%- break -%}
                    {%- endif -%}
                    {%- assign product_is_preorder = false -%}
                    {%- for product_tag in product.tags -%}
                      {%- assign normalized_product_tag = product_tag | strip | downcase -%}
                      {%- assign compact_product_tag = normalized_product_tag | replace: '-', '' | replace: '_', '' | replace: ' ', '' -%}
                      {%- if compact_product_tag == compact_preorder_tag or compact_product_tag == 'preorder' -%}
                        {%- assign product_is_preorder = true -%}
                        {%- break -%}
                      {%- endif -%}
                    {%- endfor -%}
                    {%- if product_is_preorder -%}
                      <li class="category-collection-tabs__product">
                        <span class="category-collection-tabs__preorder-badge">
                          {{ preorder_badge_label | escape }}
                        </span>
                        {% render 'card-product',
                          card_product: product,
                          media_aspect_ratio: section.settings.image_ratio,
                          show_secondary_image: section.settings.show_secondary_image,
                          show_vendor: section.settings.show_vendor,
                          show_rating: section.settings.show_rating,
                          lazy_load: true,
                          skip_styles: skip_card_product_styles,
                          section_id: section.id,
                          quick_add: 'none'
                        %}
                      </li>
                      {%- assign preorder_products_shown = preorder_products_shown | plus: 1 -%}
                      {%- assign skip_card_product_styles = true -%}
                    {%- endif -%}
                  {%- endfor -%}
                {%- endif -%}
              {%- endcapture -%}

              {%- if preorder_products_shown > 0 -%}
                <ul class="category-collection-tabs__products" role="list">
                  {{ preorder_product_cards }}
                </ul>
              {%- else -%}
                <div class="category-collection-tabs__empty">
                  <p>
                    {%- if request.design_mode and block.settings.collection == blank -%}
                      Select a collection for this category in the theme editor.
                    {%- elsif request.design_mode -%}
                      Add the “{{ preorder_tag | escape }}” product tag to products in this collection.
                    {%- else -%}
                      New pre-order products for this category are coming soon.
                    {%- endif -%}
                  </p>
                </div>
              {%- endif -%}
            </div>
          {%- endfor -%}
        </div>
      </div>
    </div>
  {%- elsif request.design_mode -%}
    <div class="category-collection-tabs__navigation">
      <div class="page-width">
        <div class="category-collection-tabs__empty">
          <p>Add a category block and choose a collection to build this section.</p>
        </div>
      </div>
    </div>
  {%- endif -%}
</category-collection-tabs>
{% schema %}
{
  "name": "Category collection tabs",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "max_blocks": 12,
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "default": "Collection Hub",
      "label": "Heading"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4,
      "label": "Products per category"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "options": [
        { "value": "adapt", "label": "Adapt to image" },
        { "value": "portrait", "label": "Portrait" },
        { "value": "square", "label": "Square" }
      ],
      "default": "square",
      "label": "Product image ratio"
    },
    {
      "type": "checkbox",
      "id": "show_secondary_image",
      "default": true,
      "label": "Show second image on hover"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "default": false,
      "label": "Show vendor"
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "default": false,
      "label": "Show product rating"
    },
    {
      "type": "header",
      "content": "Pre-order filter"
    },
    {
      "type": "text",
      "id": "preorder_tag",
      "default": "Pre-order",
      "label": "Product tag",
      "info": "Only products with this Shopify product tag appear in this section. Matching is not case-sensitive."
    },
    {
      "type": "text",
      "id": "preorder_badge_label",
      "default": "Pre-order",
      "label": "Card badge text"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "default": "#D95700",
      "label": "Background"
    },
    {
      "type": "color",
      "id": "text_color",
      "default": "#111111",
      "label": "Text"
    },
    {
      "type": "color",
      "id": "heading_color",
      "default": "#FFFFFF",
      "label": "Active category heading"
    },
    {
      "type": "color",
      "id": "card_color",
      "default": "#FFFFFF",
      "label": "Product card"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 64,
      "label": "Top padding"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 64,
      "label": "Bottom padding"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Category label",
          "info": "Leave blank to use the collection title."
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection",
          "info": "Hover previews products. Clicking opens this collection."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Category collection tabs",
      "blocks": [
        { "type": "category" },
        { "type": "category" },
        { "type": "category" },
        { "type": "category" }
      ]
    }
  ]
}
{% endschema %}
