{{ 'section-product-feature.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="product-feature page-width page-width--narrow section-{{ section.id }}-padding">
    <h2 class="product-feature__heading {{ section.settings.heading_size }}">
      {{ section.settings.heading }}
    </h2>

    <div class="product-feature__intro rte">
      {{ section.settings.intro_text }}
    </div>

    {%- if section.settings.show_contents -%}
      <div class="product-feature__section">
        <h3 class="product-feature__subheading">{{ section.settings.contents_title }}</h3>
        <div class="product-feature__contents">
          {%- for i in (1..6) -%}
            {%- assign item_label = 'contents_item_' | append: i -%}
            {%- assign item_img = 'contents_image_' | append: i -%}
            {%- if section.settings[item_label] != blank -%}
              <div class="product-feature__content-item">
                {%- if section.settings[item_img] != blank -%}
                  <div class="product-feature__content-image">
                    {{ section.settings[item_img] | image_url: width: 200 | image_tag: loading: 'lazy' }}
                  </div>
                {%- endif -%}
                <span class="product-feature__content-label">{{ section.settings[item_label] }}</span>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}

    {%- if section.settings.show_details -%}
      <div class="product-feature__section">
        <h3 class="product-feature__subheading">{{ section.settings.details_title }}</h3>
        <div class="product-feature__details rte">
          {{ section.settings.details_text }}
        </div>
        <div class="product-feature__gallery">
          {%- for i in (1..6) -%}
            {%- assign img_id = 'detail_image_' | append: i -%}
            {%- if section.settings[img_id] != blank -%}
              <div class="product-feature__gallery-item">
                {{ section.settings[img_id] | image_url: width: 800 | image_tag: loading: 'lazy' }}
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}

    {%- if section.settings.show_size_chart -%}
      <div class="product-feature__section">
        <h3 class="product-feature__subheading">{{ section.settings.size_chart_title }}</h3>
        <div class="product-feature__size-chart rte">
          {{ section.settings.size_chart_text }}
        </div>
        {%- if section.settings.size_chart_image != blank -%}
          <div class="product-feature__size-image">
            {{ section.settings.size_chart_image | image_url: width: 800 | image_tag: loading: 'lazy' }}
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
