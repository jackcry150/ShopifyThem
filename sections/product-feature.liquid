{{ 'section-product-feature.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{%- liquid
  assign included_items_metafield = product.metafields.custom.package_includes | default: product.metafields.custom.included_items | default: product.metafields.custom.whats_included | default: product.metafields.custom.product_contents
  assign notice_metafield = product.metafields.custom.notice | default: product.metafields.custom.product_notice | default: product.metafields.custom.notes
  assign order_metafield = product.metafields.custom.order | default: product.metafields.custom.order_information | default: product.metafields.custom.order_info
-%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <product-feature-tabs
    id="product-feature-details"
    class="product-feature product-feature--tabs page-width section-{{ section.id }}-padding"
    data-section-id="{{ section.id }}"
  >
    <div class="product-feature__header">
      <h2 class="product-feature__heading {{ section.settings.heading_size }}">
        {{ section.settings.heading }}
      </h2>
    </div>

    <div class="product-feature__tabs-shell">
      <div class="product-feature__tab-nav" role="tablist" aria-label="Product feature tabs">
      <button class="product-feature__tab-button is-active" type="button" role="tab" aria-selected="true" aria-controls="ProductFeaturePanel-{{ section.id }}-concept" id="ProductFeatureTab-{{ section.id }}-concept" data-tab-target="concept">
        {{ section.settings.heading | default: 'Design Concept' }}
      </button>
      <button class="product-feature__tab-button" type="button" role="tab" aria-selected="false" aria-controls="ProductFeaturePanel-{{ section.id }}-includes" id="ProductFeatureTab-{{ section.id }}-includes" data-tab-target="includes">
        {{ section.settings.contents_title | default: 'Package Includes' }}
      </button>
      <button class="product-feature__tab-button" type="button" role="tab" aria-selected="false" aria-controls="ProductFeaturePanel-{{ section.id }}-highlights" id="ProductFeatureTab-{{ section.id }}-highlights" data-tab-target="highlights">
        Design Highlights
      </button>
      <button class="product-feature__tab-button" type="button" role="tab" aria-selected="false" aria-controls="ProductFeaturePanel-{{ section.id }}-specs" id="ProductFeatureTab-{{ section.id }}-specs" data-tab-target="specs">
        Fabric & Size
      </button>
      <button class="product-feature__tab-button" type="button" role="tab" aria-selected="false" aria-controls="ProductFeaturePanel-{{ section.id }}-styling" id="ProductFeatureTab-{{ section.id }}-styling" data-tab-target="styling">
        Styling Guide
      </button>
      <button class="product-feature__tab-button" type="button" role="tab" aria-selected="false" aria-controls="ProductFeaturePanel-{{ section.id }}-notice" id="ProductFeatureTab-{{ section.id }}-notice" data-tab-target="notice">
        Notice
      </button>
    </div>

    <div class="product-feature__tab-content">
      <section class="product-feature__tab-panel is-active" role="tabpanel" id="ProductFeaturePanel-{{ section.id }}-concept" aria-labelledby="ProductFeatureTab-{{ section.id }}-concept" data-tab-panel="concept">
        <div class="product-feature__panel-inner product-feature__panel-inner--narrow rte">
          {%- if section.settings.intro_text != blank -%}
            {{ section.settings.intro_text }}
          {%- else -%}
            <p>Add the design concept, product story, and collector-facing introduction here.</p>
          {%- endif -%}
        </div>
      </section>
      <section class="product-feature__tab-panel" role="tabpanel" id="ProductFeaturePanel-{{ section.id }}-includes" aria-labelledby="ProductFeatureTab-{{ section.id }}-includes" data-tab-panel="includes" hidden>
        <div class="product-feature__panel-inner product-feature__panel-inner--narrow rte">
          {%- if included_items_metafield != blank -%}
            {{ included_items_metafield | metafield_tag }}
          {%- elsif section.settings.included_items_fallback != blank -%}
            {{ section.settings.included_items_fallback }}
          {%- else -%}
            <p>Includes the items shown for the selected product option. Doll body, display stand, background props, or extra accessories are not included unless clearly listed.</p>
          {%- endif -%}
        </div>
      </section>
      <section class="product-feature__tab-panel" role="tabpanel" id="ProductFeaturePanel-{{ section.id }}-highlights" aria-labelledby="ProductFeatureTab-{{ section.id }}-highlights" data-tab-panel="highlights" hidden>
        <div class="product-feature__highlight-editor-grid">
          <div class="product-feature__highlight-copy-panel">
            <h3 class="product-feature__subheading">Detail Gallery</h3>
            <div class="rte">
              {%- assign has_highlight_text = false -%}
              {%- for i in (1..3) -%}
                {%- assign text_id = 'highlight_' | append: i | append: '_text' -%}
                {%- if section.settings[text_id] != blank -%}
                  {%- assign has_highlight_text = true -%}
                  {{ section.settings[text_id] }}
                {%- endif -%}
              {%- endfor -%}
              {%- unless has_highlight_text -%}
                <p>Add product detail gallery copy here.</p>
              {%- endunless -%}
            </div>
          </div>
          <div class="product-feature__highlight-image-panel">
            <h3 class="product-feature__subheading">Design Highlights</h3>
            <div class="product-feature__highlight-image-grid">
              {%- assign has_highlight_image = false -%}
              {%- for i in (1..3) -%}
                {%- assign image_id = 'highlight_' | append: i | append: '_image' -%}
                {%- if section.settings[image_id] != blank -%}
                  {%- assign has_highlight_image = true -%}
                  <div class="product-feature__highlight-image">
                    {{ section.settings[image_id] | image_url: width: 900 | image_tag: loading: 'lazy' }}
                  </div>
                {%- endif -%}
              {%- endfor -%}
              {%- unless has_highlight_image -%}
                <p>Add up to three design highlight images.</p>
              {%- endunless -%}
            </div>
          </div>
        </div>
      </section>

      <section class="product-feature__tab-panel" role="tabpanel" id="ProductFeaturePanel-{{ section.id }}-specs" aria-labelledby="ProductFeatureTab-{{ section.id }}-specs" data-tab-panel="specs" hidden>
        <div class="product-feature__spec-grid">
          <article class="product-feature__spec-card">
            <h3>Fabric & Materials</h3>
            <div class="product-feature__spec-copy rte">{{ section.settings.materials_text }}</div>
          </article>
          <article class="product-feature__spec-card">
            <h3>Size Information</h3>
            <div class="product-feature__spec-copy rte">{{ section.settings.size_chart_text }}</div>
          </article>
          <article class="product-feature__spec-card">
            <h3>Model Information</h3>
            <div class="product-feature__spec-copy rte">{{ section.settings.model_text }}</div>
          </article>
        </div>
      </section>

      <section class="product-feature__tab-panel" role="tabpanel" id="ProductFeaturePanel-{{ section.id }}-styling" aria-labelledby="ProductFeatureTab-{{ section.id }}-styling" data-tab-panel="styling" hidden>
        <div class="product-feature__styling-grid">
          <article class="product-feature__styling-card">
            <h3 class="product-feature__subheading">Recommended Body Styling</h3>
            <div class="rte">{{ section.settings.compatibility_text }}</div>
          </article>
          <article class="product-feature__styling-card">
            <h3 class="product-feature__subheading">Closure Method</h3>
            <div class="rte">{{ section.settings.closure_text }}</div>
          </article>
        </div>
      </section>
      <section class="product-feature__tab-panel" role="tabpanel" id="ProductFeaturePanel-{{ section.id }}-notice" aria-labelledby="ProductFeatureTab-{{ section.id }}-notice" data-tab-panel="notice" hidden>
        <div class="product-feature__notice-grid">
          <div class="product-feature__notice-card">
            <h3 class="product-feature__subheading">Notice</h3>
            <div class="rte">
              {%- if notice_metafield != blank -%}
                {{ notice_metafield | metafield_tag }}
              {%- else -%}
                {{ section.settings.notice_text }}
              {%- endif -%}
            </div>
          </div>
          <div class="product-feature__notice-card">
            <h3 class="product-feature__subheading">Order Information</h3>
            <div class="rte">
              {%- if order_metafield != blank -%}
                {{ order_metafield | metafield_tag }}
              {%- elsif section.settings.order_info_text != blank -%}
                {{ section.settings.order_info_text }}
              {%- else -%}
                <p>Add preorder, delivery, or ordering notes in the product metafield <strong>order</strong>.</p>
              {%- endif -%}
            </div>
          </div>
          <div class="product-feature__notice-card">
            <h3 class="product-feature__subheading">Product Information</h3>
            <div class="rte">{{ section.settings.product_info_text }}</div>
          </div>
        </div>
      </section>
    </div>
    </div>
  </product-feature-tabs>
</div>

<script>
  (() => {
    if (customElements.get('product-feature-tabs')) return;

    customElements.define(
      'product-feature-tabs',
      class ProductFeatureTabs extends HTMLElement {
        connectedCallback() {
          this.tabs = Array.from(this.querySelectorAll('[data-tab-target]'));
          this.panels = Array.from(this.querySelectorAll('[data-tab-panel]'));
          this.tabs.forEach((tab) => {
            tab.addEventListener('click', () => this.switchTab(tab.dataset.tabTarget));
          });
        }

        switchTab(target) {
          this.tabs.forEach((tab) => {
            const isActive = tab.dataset.tabTarget === target;
            tab.classList.toggle('is-active', isActive);
            tab.setAttribute('aria-selected', isActive ? 'true' : 'false');
          });

          this.panels.forEach((panel) => {
            const isActive = panel.dataset.tabPanel === target;
            panel.classList.toggle('is-active', isActive);
            panel.hidden = !isActive;
          });
        }
      }
    );
  })();
</script>
{% schema %}
{
  "name": "Product Feature",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Design Concept"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h2", "label": "t:sections.all.heading_size.options__1.label" },
        { "value": "h1", "label": "t:sections.all.heading_size.options__2.label" },
        { "value": "h0", "label": "t:sections.all.heading_size.options__3.label" }
      ],
      "default": "h2",
      "label": "t:sections.all.heading_size.label"
    },
    {
      "type": "richtext",
      "id": "intro_text",
      "label": "Design concept text",
      "default": "<p>Describe the design concept and product story.</p>"
    },
    {
      "type": "header",
      "content": "Included Items"
    },
    {
      "type": "text",
      "id": "contents_title",
      "label": "Included items title",
      "default": "Included Items"
    },
    {
      "type": "richtext",
      "id": "included_items_fallback",
      "label": "Included items fallback text",
      "info": "Used when product metafields custom.package_includes, custom.included_items, custom.whats_included, or custom.product_contents are empty.",
      "default": "<p>Includes the items shown for the selected product option. Doll body, display stand, background props, or extra accessories are not included unless clearly listed.</p>"
    },
    {
      "type": "header",
      "content": "Design Highlights"
    },
    {
      "type": "richtext",
      "id": "highlight_1_text",
      "label": "Detail Gallery text 1",
      "default": "<p>Highlight 1: describe clothing display details.</p>"
    },
    {
      "type": "image_picker",
      "id": "highlight_1_image",
      "label": "Design Highlight image 1"
    },
    {
      "type": "richtext",
      "id": "highlight_2_text",
      "label": "Detail Gallery text 2",
      "default": "<p>Highlight 2: describe styling or matching details.</p>"
    },
    {
      "type": "image_picker",
      "id": "highlight_2_image",
      "label": "Design Highlight image 2"
    },
    {
      "type": "richtext",
      "id": "highlight_3_text",
      "label": "Detail Gallery text 3",
      "default": "<p>Highlight 3: describe craftsmanship details.</p>"
    },
    {
      "type": "image_picker",
      "id": "highlight_3_image",
      "label": "Design Highlight image 3"
    },
    {
      "type": "header",
      "content": "Fabric, Size, Model"
    },
    {
      "type": "richtext",
      "id": "materials_text",
      "label": "Materials text",
      "default": "<p>Main Fabric<br>________________</p><p>Lining<br>________________</p><p>Trim<br>________________</p><p>Metal Parts<br>________________</p><p>Accessories<br>________________</p>"
    },
    {
      "type": "richtext",
      "id": "size_chart_text",
      "label": "Size information text",
      "default": "<p>Top Length<br>__________</p><p>Shoulder Width<br>__________</p><p>Chest Width<br>__________</p><p>Sleeve Length<br>__________</p><p>Waist Width<br>__________</p><p>Hip Width<br>__________</p>"
    },
    {
      "type": "richtext",
      "id": "model_text",
      "label": "Model information text",
      "default": "<p>Body<br>________________</p><p>Head<br>________________</p><p>Height<br>________________</p><p>Bust<br>________________</p><p>Waist<br>________________</p><p>Hip<br>________________</p>"
    },
    {
      "type": "header",
      "content": "Compatibility"
    },
    {
      "type": "richtext",
      "id": "compatibility_text",
      "label": "Compatibility text",
      "default": "<p>Recommended body and styling notes.</p>"
    },
    {
      "type": "header",
      "content": "Closure Method"
    },
    {
      "type": "richtext",
      "id": "closure_text",
      "label": "Closure text",
      "default": "<p>Top<br>________________</p><p>Dress<br>________________</p><p>Skirt<br>________________</p><p>Pants<br>________________</p><p>Accessories<br>________________</p>"
    },
    {
      "type": "header",
      "content": "Product Information"
    },
    {
      "type": "richtext",
      "id": "product_info_text",
      "label": "Product information text",
      "default": "<p>Category<br>Doll Outfit</p><p>Collection<br>________________</p><p>Style<br>________________</p><p>Scale<br>________________</p><p>Brand<br>GOOMOOPLAY</p><p>Origin<br>________________</p>"
    },
    {
      "type": "header",
      "content": "Notice"
    },
    {
      "type": "richtext",
      "id": "notice_text",
      "label": "Notice text",
      "default": "<p>Dark-colored fabrics may cause staining after prolonged contact.</p><p>Please avoid storing dolls while wearing dark-colored clothing for long periods.</p><p>Minor variations may occur due to the handmade production process.</p><p>Colors may vary slightly depending on monitor settings.</p>"
    },
    {
      "type": "richtext",
      "id": "order_info_text",
      "label": "Order information fallback text",
      "info": "Used when product metafields custom.order, custom.order_information, or custom.order_info are empty.",
      "default": "<p>Pre-order and delivery information can be added in the product metafield order.</p>"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Product Feature"
    }
  ]
}
{% endschema %}
