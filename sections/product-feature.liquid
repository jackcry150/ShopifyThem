{{ 'section-product-feature.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div id="product-feature-details" class="product-feature product-feature--reference page-width section-{{ section.id }}-padding">
    <h2 class="product-feature__heading {{ section.settings.heading_size }}">
      {{ section.settings.heading }}
    </h2>

    {%- if section.settings.intro_text != blank -%}
      <div class="product-feature__intro rte">
        {{ section.settings.intro_text }}
      </div>
    {%- endif -%}

    {%- unless section.settings.show_contents == false -%}
      <section class="product-feature__section">
        <h3 class="product-feature__subheading">{{ section.settings.contents_title }}</h3>
        <div class="product-feature__contents">
          {%- for i in (1..6) -%}
            {%- assign item_label = 'contents_item_' | append: i -%}
            {%- assign item_img = 'contents_image_' | append: i -%}
            {%- if section.settings[item_label] != blank or section.settings[item_img] != blank -%}
              <div class="product-feature__content-item">
                {%- if section.settings[item_img] != blank -%}
                  <div class="product-feature__content-image">
                    {{ section.settings[item_img] | image_url: width: 360 | image_tag: loading: 'lazy' }}
                  </div>
                {%- endif -%}
                {%- if section.settings[item_label] != blank -%}
                  <span class="product-feature__content-label">{{ section.settings[item_label] }}</span>
                {%- endif -%}
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </section>
    {%- endunless -%}

    {%- unless section.settings.show_details == false -%}
      <section class="product-feature__section">
        <h3 class="product-feature__subheading">{{ section.settings.details_title }}</h3>
        {%- if section.settings.details_text != blank -%}
          <div class="product-feature__details rte">
            {{ section.settings.details_text }}
          </div>
        {%- endif -%}
        <div class="product-feature__gallery">
          {%- for i in (1..6) -%}
            {%- assign img_id = 'detail_image_' | append: i -%}
            {%- if section.settings[img_id] != blank -%}
              <div class="product-feature__gallery-item">
                {{ section.settings[img_id] | image_url: width: 900 | image_tag: loading: 'lazy' }}
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </section>
    {%- endunless -%}

    <section class="product-feature__section">
      <h3 class="product-feature__subheading">Design Highlights</h3>
      <div class="product-feature__highlight-list">
        {%- for i in (1..3) -%}
          {%- assign text_id = 'highlight_' | append: i | append: '_text' -%}
          {%- assign image_id = 'highlight_' | append: i | append: '_image' -%}
          {%- if section.settings[text_id] != blank or section.settings[image_id] != blank -%}
            <article class="product-feature__highlight">
              {%- if section.settings[text_id] != blank -%}
                <div class="product-feature__highlight-copy rte">
                  {{ section.settings[text_id] }}
                </div>
              {%- endif -%}
              {%- if section.settings[image_id] != blank -%}
                <div class="product-feature__highlight-image">
                  {{ section.settings[image_id] | image_url: width: 1000 | image_tag: loading: 'lazy' }}
                </div>
              {%- endif -%}
            </article>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </section>

    <section class="product-feature__section">
      <h3 class="product-feature__subheading">Fabric & Materials</h3>
      <div class="product-feature__spec-grid">
        <article class="product-feature__spec-card">
          <h4>Fabric & Materials</h4>
          <div class="product-feature__spec-copy rte">{{ section.settings.materials_text }}</div>
          {%- if section.settings.materials_image != blank -%}
            {{ section.settings.materials_image | image_url: width: 700 | image_tag: loading: 'lazy' }}
          {%- endif -%}
        </article>
        <article class="product-feature__spec-card">
          <h4>Size Information</h4>
          <div class="product-feature__spec-copy rte">{{ section.settings.size_chart_text }}</div>
          {%- if section.settings.size_chart_image != blank -%}
            {{ section.settings.size_chart_image | image_url: width: 700 | image_tag: loading: 'lazy' }}
          {%- endif -%}
        </article>
        <article class="product-feature__spec-card">
          <h4>Model Information</h4>
          <div class="product-feature__spec-copy rte">{{ section.settings.model_text }}</div>
          {%- if section.settings.model_image != blank -%}
            {{ section.settings.model_image | image_url: width: 700 | image_tag: loading: 'lazy' }}
          {%- endif -%}
        </article>
      </div>
    </section>

    <section class="product-feature__section product-feature__two-column">
      <div>
        <h3 class="product-feature__subheading">Recommended Body Styling</h3>
        <div class="rte">{{ section.settings.compatibility_text }}</div>
      </div>
      {%- if section.settings.compatibility_image != blank -%}
        <div class="product-feature__side-media">
          {{ section.settings.compatibility_image | image_url: width: 900 | image_tag: loading: 'lazy' }}
        </div>
      {%- endif -%}
    </section>

    <section class="product-feature__section product-feature__two-column">
      <div>
        <h3 class="product-feature__subheading">Closure Method</h3>
        <div class="rte">{{ section.settings.closure_text }}</div>
      </div>
      {%- if section.settings.closure_image != blank -%}
        <div class="product-feature__side-media">
          {{ section.settings.closure_image | image_url: width: 900 | image_tag: loading: 'lazy' }}
        </div>
      {%- endif -%}
    </section>

    <section class="product-feature__section product-feature__two-column">
      <div>
        <h3 class="product-feature__subheading">Product Information</h3>
        <div class="rte">{{ section.settings.product_info_text }}</div>
      </div>
      {%- if section.settings.product_info_image != blank -%}
        <div class="product-feature__side-media">
          {{ section.settings.product_info_image | image_url: width: 900 | image_tag: loading: 'lazy' }}
        </div>
      {%- endif -%}
    </section>

    <section class="product-feature__section product-feature__two-column">
      <div>
        <h3 class="product-feature__subheading">Notice</h3>
        <div class="rte">{{ section.settings.notice_text }}</div>
      </div>
      {%- if section.settings.notice_image != blank -%}
        <div class="product-feature__side-media">
          {{ section.settings.notice_image | image_url: width: 900 | image_tag: loading: 'lazy' }}
        </div>
      {%- endif -%}
    </section>
  </div>
</div>

