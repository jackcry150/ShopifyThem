{{ 'section-wholesale-contact.css' | asset_url | stylesheet_tag }}
{{ 'section-contact-form.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="wholesale page-width page-width--narrow section-{{ section.id }}-padding">
    <h1 class="wholesale__heading {{ section.settings.heading_size }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
      {{ section.settings.heading }}
    </h1>

    <div class="wholesale__content{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
      <p class="wholesale__tagline">{{ section.settings.tagline }}</p>
      <div class="wholesale__body rte">
        {{ section.settings.body_text }}
      </div>
      <p class="wholesale__email-label">
        {{- 'templates.contact.form.email_label' | t }}
        <a href="mailto:{{ section.settings.contact_email }}" class="wholesale__email">{{ section.settings.contact_email }}</a>
      </p>
    </div>

    <hr class="wholesale__divider">

    <p class="wholesale__form-heading{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
      {{ section.settings.form_heading }}
    </p>

    {%- liquid
      assign contact_form_class = 'isolate'
      if settings.animations_reveal_on_scroll
        assign contact_form_class = 'isolate scroll-trigger animate--slide-in'
      endif
    -%}
    {%- form 'contact', id: 'WholesaleForm', class: contact_form_class -%}
      {%- if form.posted_successfully? -%}
        <h2 class="form-status form-status-list form__message" tabindex="-1" autofocus>
          {{- 'icon-success.svg' | inline_asset_content -}}
          {{ 'templates.contact.form.post_success' | t }}
        </h2>
      {%- elsif form.errors -%}
        <div class="form__message">
          <h2 class="form-status caption-large text-body" role="alert" tabindex="-1" autofocus>
            {{- 'icon-error.svg' | inline_asset_content -}}
            {{ 'templates.contact.form.error_heading' | t }}
          </h2>
        </div>
        <ul class="form-status-list caption-large" role="list">
          <li>
            <a href="#ContactForm-email" class="link">
              {{ form.errors.translated_fields.email | capitalize }}
              {{ form.errors.messages.email }}
            </a>
          </li>
        </ul>
      {%- endif -%}
      <div class="field">
        <input
          class="field__input"
          autocomplete="name"
          type="text"
          id="ContactForm-name"
          name="contact[{{ 'templates.contact.form.name' | t }}]"
          value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}"
          placeholder="{{ 'templates.contact.form.name' | t }}"
        >
        <label class="field__label" for="ContactForm-name">{{ 'templates.contact.form.name' | t }}</label>
      </div>
      <div class="field field--with-error">
        <input
          autocomplete="email"
          type="email"
          id="ContactForm-email"
          class="field__input"
          name="contact[email]"
          spellcheck="false"
          autocapitalize="off"
          value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
          aria-required="true"
          required
          {% if form.errors contains 'email' %}
            aria-invalid="true"
            aria-describedby="ContactForm-email-error"
          {% endif %}
          placeholder="{{ 'templates.contact.form.email' | t }}"
        >
        <label class="field__label" for="ContactForm-email">
          {{- 'templates.contact.form.email' | t }}
          <span aria-hidden="true">*</span>
        </label>
        {%- if form.errors contains 'email' -%}
          <small class="contact__field-error" id="ContactForm-email-error">
            <span class="visually-hidden">{{ 'accessibility.error' | t }}</span>
            <span class="form__message">
              <span class="svg-wrapper">{{- 'icon-error.svg' | inline_asset_content -}}</span>
              {{- form.errors.translated_fields.email | capitalize }}
              {{ form.errors.messages.email -}}
            </span>
          </small>
        {%- endif -%}
      </div>
      <fieldset class="wholesale__radio-group">
        <legend class="wholesale__radio-legend">{{ 'templates.wholesale.form.need_partner' | t }} <span aria-hidden="true">*</span></legend>
        <label class="wholesale__radio">
          <input type="radio" name="contact[{{ 'templates.wholesale.form.need_partner' | t }}]" value="Yes" required>
          <span>{{ 'templates.wholesale.form.yes' | t }}</span>
        </label>
        <label class="wholesale__radio">
          <input type="radio" name="contact[{{ 'templates.wholesale.form.need_partner' | t }}]" value="No">
          <span>{{ 'templates.wholesale.form.no' | t }}</span>
        </label>
      </fieldset>
      <fieldset class="wholesale__radio-group">
        <legend class="wholesale__radio-legend">{{ 'templates.wholesale.form.have_store' | t }} <span aria-hidden="true">*</span></legend>
        <label class="wholesale__radio">
          <input type="radio" name="contact[{{ 'templates.wholesale.form.have_store' | t }}]" value="Yes" required>
          <span>{{ 'templates.wholesale.form.yes' | t }}</span>
        </label>
        <label class="wholesale__radio">
          <input type="radio" name="contact[{{ 'templates.wholesale.form.have_store' | t }}]" value="No">
          <span>{{ 'templates.wholesale.form.no' | t }}</span>
        </label>
      </fieldset>
      <fieldset class="wholesale__radio-group">
        <legend class="wholesale__radio-legend">{{ 'templates.wholesale.form.business_started' | t }} <span aria-hidden="true">*</span></legend>
        <label class="wholesale__radio">
          <input type="radio" name="contact[{{ 'templates.wholesale.form.business_started' | t }}]" value="{{ 'templates.wholesale.form.business_months' | t }}" required>
          <span>{{ 'templates.wholesale.form.business_months' | t }}</span>
        </label>
        <label class="wholesale__radio">
          <input type="radio" name="contact[{{ 'templates.wholesale.form.business_started' | t }}]" value="{{ 'templates.wholesale.form.business_year' | t }}">
          <span>{{ 'templates.wholesale.form.business_year' | t }}</span>
        </label>
        <label class="wholesale__radio">
          <input type="radio" name="contact[{{ 'templates.wholesale.form.business_started' | t }}]" value="{{ 'templates.wholesale.form.business_years' | t }}">
          <span>{{ 'templates.wholesale.form.business_years' | t }}</span>
        </label>
        <label class="wholesale__radio">
          <input type="radio" name="contact[{{ 'templates.wholesale.form.business_started' | t }}]" value="{{ 'templates.wholesale.form.business_not_yet' | t }}">
          <span>{{ 'templates.wholesale.form.business_not_yet' | t }}</span>
        </label>
      </fieldset>
      <div class="field">
        <input
          class="field__input"
          type="text"
          id="ContactForm-country"
          name="contact[{{ 'templates.wholesale.form.country' | t }}]"
          placeholder="{{ 'templates.wholesale.form.country' | t }}"
        >
        <label class="field__label" for="ContactForm-country">{{ 'templates.wholesale.form.country' | t }}</label>
      </div>
      <div class="field">
        <input
          class="field__input"
          type="text"
          id="ContactForm-interest"
          name="contact[{{ 'templates.wholesale.form.interest' | t }}]"
          placeholder="{{ 'templates.wholesale.form.interest' | t }}"
        >
        <label class="field__label" for="ContactForm-interest">{{ 'templates.wholesale.form.interest' | t }}</label>
      </div>
      <div class="field">
        <textarea
          rows="8"
          id="ContactForm-body"
          class="text-area field__input"
          name="contact[{{ 'templates.contact.form.comment' | t }}]"
          placeholder="{{ 'templates.wholesale.form.message' | t }}"
        >
          {{- form.body -}}
        </textarea>
        <label class="form__label field__label" for="ContactForm-body">{{ 'templates.wholesale.form.message' | t }}</label>
      </div>
      <div class="contact__button">
        <button type="submit" class="button">
          {{ 'templates.contact.form.send' | t }}
        </button>
      </div>
      <p class="wholesale__required-note">{{ 'templates.contact.form.required_note' | t }}</p>
    {%- endform -%}

    <p class="wholesale__captcha-notice">{{ 'templates.contact.form.captcha_notice' | t }}</p>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.wholesale-contact.name",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.wholesale-contact.settings.heading.label",
      "default": "Wholesale"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h2", "label": "t:sections.all.heading_size.options__1.label" },
        { "value": "h1", "label": "t:sections.all.heading_size.options__2.label" },
        { "value": "h0", "label": "t:sections.all.heading_size.options__3.label" }
      ],
      "default": "h1",
      "label": "t:sections.all.heading_size.label"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "t:sections.wholesale-contact.settings.tagline.label",
      "default": "We are looking for new partners!"
    },
    {
      "type": "richtext",
      "id": "body_text",
      "label": "t:sections.wholesale-contact.settings.body_text.label",
      "default": "<p>We are looking for creative gift shops, toy stores, drop-shipping shops, and art galleries around the world to bring our unique products to more customers. We offer blind boxes and collectible toys, and support a variety of logistics and transaction methods to make cooperation easy.</p><p>We also welcome brands, designers, and original studios — we can assist in design, manufacturing, social media distribution, marketing and branding. Hope our cooperation can bring more happiness to the world.</p>"
    },
    {
      "type": "text",
      "id": "contact_email",
      "label": "t:sections.wholesale-contact.settings.contact_email.label",
      "default": "marketing@goomooplay.com"
    },
    {
      "type": "text",
      "id": "form_heading",
      "label": "t:sections.wholesale-contact.settings.form_heading.label",
      "default": "Fill out information below and we will contact you shortly"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "t:sections.wholesale-contact.presets.name"
    }
  ]
}
{% endschema %}
