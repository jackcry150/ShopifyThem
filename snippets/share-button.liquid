{% comment %}
  Renders share button with social media buttons.
  Accepts:
  - block: {Object} passes in the block information.
  - share_link: {String} url to be added to the input the user will get/copy.

  Usage:
  {% render 'share-button',
    block: block,
    share_link: share_url
  %}
{% endcomment %}
<script src="{{ 'share.js' | asset_url }}" defer="defer"></script>

<share-button id="Share-{{ section.id }}" class="share-button quick-add-hidden" {{ block.shopify_attributes }}>
  <button class="share-button__button hidden">
    <span class="svg-wrapper">{{ 'icon-share.svg' | inline_asset_content }}</span>
    {{ block.settings.share_label | escape }}
  </button>
  <details id="Details-{{ block.id }}-{{ section.id }}">
    <summary class="share-button__button">
      <span class="svg-wrapper">{{ 'icon-share.svg' | inline_asset_content }}</span>
      {{ block.settings.share_label | escape }}
    </summary>
    <div class="share-button__fallback motion-reduce">
      <div class="field">
        <span id="ShareMessage-{{ section.id }}" class="share-button__message hidden" role="status"> </span>
        <input
          type="text"
          class="field__input"
          id="ShareUrl-{{ section.id }}"
          value="{{ share_link }}"
          placeholder="{{ 'general.share.share_url' | t }}"
          onclick="this.select();"
          readonly
        >
        <label class="field__label" for="ShareUrl-{{ section.id }}">{{ 'general.share.share_url' | t }}</label>
      </div>
      <button class="share-button__close hidden">
        <span class="svg-wrapper">
          {{- 'icon-close.svg' | inline_asset_content -}}
        </span>
        <span class="visually-hidden">{{ 'general.share.close' | t }}</span>
      </button>
      <button class="share-button__copy">
        <span class="svg-wrapper">
          {{- 'icon-copy.svg' | inline_asset_content -}}
        </span>
        <span class="visually-hidden">{{ 'general.share.copy_to_clipboard' | t }}</span>
      </button>
    </div>
    <div class="share-button__social">
      <span class="share-button__social-title">{{ 'general.share.share_on' | t }}</span>
      <div class="share-button__social-icons">
        <a class="share-button__social-link" href="https://www.facebook.com/sharer/sharer.php?u={{ share_link | url_encode }}" target="_blank" rel="noopener" aria-label="Facebook">
          {{- 'icon-facebook.svg' | inline_asset_content -}}
        </a>
        <a class="share-button__social-link" href="https://twitter.com/intent/tweet?url={{ share_link | url_encode }}" target="_blank" rel="noopener" aria-label="X (Twitter)">
          {{- 'icon-twitter.svg' | inline_asset_content -}}
        </a>
        <a class="share-button__social-link" href="https://pinterest.com/pin/create/button/?url={{ share_link | url_encode }}" target="_blank" rel="noopener" aria-label="Pinterest">
          {{- 'icon-pinterest.svg' | inline_asset_content -}}
        </a>
        <a class="share-button__social-link" href="https://www.tiktok.com/share?url={{ share_link | url_encode }}" target="_blank" rel="noopener" aria-label="TikTok">
          {{- 'icon-tiktok.svg' | inline_asset_content -}}
        </a>
        <a class="share-button__social-link" href="https://www.instagram.com/?url={{ share_link | url_encode }}" target="_blank" rel="noopener" aria-label="Instagram">
          {{- 'icon-instagram.svg' | inline_asset_content -}}
        </a>
        <a class="share-button__social-link" href="https://share.naver.com/web/shareView.nhn?url={{ share_link | url_encode }}" target="_blank" rel="noopener" aria-label="Naver">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
            <rect x="2" y="5" width="16" height="10" rx="2" stroke="currentColor" stroke-width="1.3"/>
            <path d="M5 10.5h3v4H5zM12 5.5h3v9h-3zM8.5 10v4.5M11.5 5.5V15" stroke="currentColor" stroke-width="1.3"/>
          </svg>
        </a>
        <a class="share-button__social-link" href="https://story.kakao.com/share?url={{ share_link | url_encode }}" target="_blank" rel="noopener" aria-label="KakaoTalk">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
            <circle cx="10" cy="9" r="6" stroke="currentColor" stroke-width="1.3"/>
            <path d="M7 9h6M10 6v6" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
          </svg>
        </a>
        <a class="share-button__social-link" href="https://social-plugins.line.me/lineit/share?url={{ share_link | url_encode }}" target="_blank" rel="noopener" aria-label="Line">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
            <circle cx="10" cy="10" r="7" stroke="currentColor" stroke-width="1.3"/>
            <circle cx="7" cy="9" r="1.5" fill="currentColor"/>
            <circle cx="13" cy="9" r="1.5" fill="currentColor"/>
            <path d="M7 12q3 3 6 0" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
          </svg>
        </a>
      </div>
    </div>
  </details>
</share-button>

<style>
  .share-button__social {
    border-top: 1px solid rgb(var(--color-foreground), 0.08);
    padding-top: 12px;
    margin-top: 8px;
  }
  .share-button__social-title {
    display: block;
    font-size: 12px;
    color: rgb(var(--color-foreground), 0.55);
    margin-bottom: 10px;
  }
  .share-button__social-icons {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .share-button__social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 1px solid rgb(var(--color-foreground), 0.15);
    color: rgb(var(--color-foreground));
    transition: all 0.15s ease;
    text-decoration: none;
  }
  .share-button__social-link:hover {
    background: rgb(var(--color-foreground), 0.06);
    border-color: rgb(var(--color-foreground), 0.3);
  }
  .share-button__social-link svg {
    width: 18px;
    height: 18px;
  }
</style>
