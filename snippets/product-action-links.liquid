{% comment %}
  Product detail accordions and delivery estimate used below the buy buttons.
{% endcomment %}

{%- liquid
  assign size_metafield = product.metafields.custom.product_sizes | default: product.metafields.custom.size_information | default: product.metafields.custom.size_chart | default: product.metafields.custom.sizing
  assign included_metafield = product.metafields.custom.included_items | default: product.metafields.custom.package_includes | default: product.metafields.custom.whats_included | default: product.metafields.custom.product_contents
-%}

<div class="product-action-links product-detail-accordions" data-product-detail-accordions>
  <details class="product-detail-accordion">
    <summary class="product-detail-accordion__summary">
      <span>{{ product_section.settings.product_details_size_title | default: 'PRODUCT SIZES' }}</span>
      {{- 'icon-caret.svg' | inline_asset_content -}}
    </summary>
    <div class="product-detail-accordion__content rte">
      {%- if size_metafield != blank -%}
        {{ size_metafield | metafield_tag }}
      {%- elsif product_section.settings.product_details_size_content != blank -%}
        {{ product_section.settings.product_details_size_content }}
      {%- else -%}
        <p>Fits 1/6, 1/12, OB11, BJD, or other compatible dolls as described by this product. Please check the product photos and option name before ordering.</p>
      {%- endif -%}
    </div>
  </details>

  <details class="product-detail-accordion">
    <summary class="product-detail-accordion__summary">
      <span>{{ product_section.settings.product_details_included_title | default: 'INCLUDED ITEMS' }}</span>
      {{- 'icon-caret.svg' | inline_asset_content -}}
    </summary>
    <div class="product-detail-accordion__content rte">
      {%- if included_metafield != blank -%}
        {{ included_metafield | metafield_tag }}
      {%- elsif product_section.settings.product_details_included_content != blank -%}
        {{ product_section.settings.product_details_included_content }}
      {%- else -%}
        <p>Includes the items shown for the selected product option. Doll body, display stand, background props, or extra accessories are not included unless clearly listed.</p>
      {%- endif -%}
    </div>
  </details>
</div>

{%- if product_section.settings.show_delivery_timeline -%}
  <div class="product-delivery-timeline" aria-label="Estimated shipping time">
    <p class="product-delivery-timeline__heading">
      {{ product_section.settings.delivery_timeline_heading | default: 'Estimated Shipping time:' }}
    </p>
    <ol class="product-delivery-timeline__steps" role="list">
      <li class="product-delivery-timeline__step">
        <span class="product-delivery-timeline__icon" aria-hidden="true">
          {% render 'icon-accordion', icon: 'cart' %}
        </span>
        <span class="product-delivery-timeline__title">{{ product_section.settings.delivery_step_1_title | default: 'Confirm' }}</span>
        <span class="product-delivery-timeline__text">{{ product_section.settings.delivery_step_1_text | default: 'Order confirmation within 48 hours' }}</span>
      </li>
      <li class="product-delivery-timeline__step">
        <span class="product-delivery-timeline__icon" aria-hidden="true">
          {% render 'icon-accordion', icon: 'truck' %}
        </span>
        <span class="product-delivery-timeline__title">{{ product_section.settings.delivery_step_2_title | default: 'Shipping' }}</span>
        <span class="product-delivery-timeline__text">{{ product_section.settings.delivery_step_2_text | default: '10-15 working days from order confirmation' }}</span>
      </li>
      <li class="product-delivery-timeline__step">
        <span class="product-delivery-timeline__icon" aria-hidden="true">
          {% render 'icon-accordion', icon: 'box' %}
        </span>
        <span class="product-delivery-timeline__title">{{ product_section.settings.delivery_step_3_title | default: 'Delivered' }}</span>
        <span class="product-delivery-timeline__text">{{ product_section.settings.delivery_step_3_text | default: '15-20 working days from order confirmation' }}</span>
      </li>
    </ol>
  </div>
{%- endif -%}
