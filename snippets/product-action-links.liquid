{% comment %}
  Delivery estimate displayed below the buy buttons.
{% endcomment %}

{%- if product_section.settings.show_delivery_timeline -%}
  <div class="product-delivery-timeline" aria-label="Estimated shipping time">
    <p class="product-delivery-timeline__heading">
      {{ product_section.settings.delivery_timeline_heading | default: 'Estimated Shipping time:' }}
    </p>
    <ol class="product-delivery-timeline__steps" role="list">
      <li class="product-delivery-timeline__step">
        <span class="product-delivery-timeline__icon" aria-hidden="true">
          {% render 'icon-accordion', icon: 'cart' %}
        </span>
        <span class="product-delivery-timeline__title">{{ product_section.settings.delivery_step_1_title | default: 'Confirm' }}</span>
        <span class="product-delivery-timeline__text">{{ product_section.settings.delivery_step_1_text | default: 'Order confirmation within 48 hours' }}</span>
      </li>
      <li class="product-delivery-timeline__step">
        <span class="product-delivery-timeline__icon" aria-hidden="true">
          {% render 'icon-accordion', icon: 'truck' %}
        </span>
        <span class="product-delivery-timeline__title">{{ product_section.settings.delivery_step_2_title | default: 'Shipping' }}</span>
        <span class="product-delivery-timeline__text">{{ product_section.settings.delivery_step_2_text | default: '10-15 working days from order confirmation' }}</span>
      </li>
      <li class="product-delivery-timeline__step">
        <span class="product-delivery-timeline__icon" aria-hidden="true">
          {% render 'icon-accordion', icon: 'box' %}
        </span>
        <span class="product-delivery-timeline__title">{{ product_section.settings.delivery_step_3_title | default: 'Delivered' }}</span>
        <span class="product-delivery-timeline__text">{{ product_section.settings.delivery_step_3_text | default: '15-20 working days from order confirmation' }}</span>
      </li>
    </ol>
  </div>
{%- endif -%}
