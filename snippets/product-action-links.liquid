{% comment %}
  Product detail action links used below the buy buttons.
{% endcomment %}

{%- liquid
  assign contact_email = shop.email | default: 'contact@goomooplay.com'
  assign product_share_url = product.selected_variant.url | default: product.url | prepend: request.origin
  assign shipping_url = shop.shipping_policy.url | default: '/policies/shipping-policy'
-%}

<div class="product-action-links" data-product-action-links>
  <a
    class="product-action-links__item"
    href="mailto:{{ contact_email }}?subject={{ 'Question about ' | append: product.title | url_encode }}&body={{ product_share_url | url_encode }}"
  >
    <span class="product-action-links__icon" aria-hidden="true">
      {% render 'icon-accordion', icon: 'question_mark' %}
    </span>
    <span>Ask question</span>
  </a>

  <button
    class="product-action-links__item"
    type="button"
    data-product-share-button
    data-share-title="{{ product.title | escape }}"
    data-share-url="{{ product_share_url }}"
  >
    <span class="product-action-links__icon" aria-hidden="true">
      {% render 'icon-accordion', icon: 'share' %}
    </span>
    <span data-share-label>Share</span>
  </button>

  <a class="product-action-links__item" href="{{ shipping_url }}">
    <span class="product-action-links__icon" aria-hidden="true">
      {% render 'icon-accordion', icon: 'truck' %}
    </span>
    <span>Shipping</span>
  </a>
</div>

<script>
  (() => {
    const roots = document.querySelectorAll('[data-product-action-links]');
    roots.forEach((root) => {
      const button = root.querySelector('[data-product-share-button]');
      if (!button || button.dataset.bound === 'true') return;

      button.dataset.bound = 'true';
      button.addEventListener('click', async () => {
        const title = button.dataset.shareTitle || document.title;
        const url = button.dataset.shareUrl || window.location.href;
        const label = button.querySelector('[data-share-label]');

        try {
          if (navigator.share) {
            await navigator.share({ title, url });
          } else if (navigator.clipboard) {
            await navigator.clipboard.writeText(url);
            if (label) {
              label.textContent = 'Copied';
              window.setTimeout(() => {
                label.textContent = 'Share';
              }, 1800);
            }
          } else {
            window.prompt('Copy this link', url);
          }
        } catch (error) {
          if (error && error.name !== 'AbortError') {
            window.prompt('Copy this link', url);
          }
        }
      });
    });
  })();
</script>
