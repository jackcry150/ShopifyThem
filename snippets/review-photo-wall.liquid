{% comment %}
  Renders a photo wall of curated user review images from Judge.me.
  Usage: {%- render 'review-photo-wall', product: product -%}
{% endcomment %}

<div
  class="review-photo-wall"
  id="ReviewPhotoWall-{{ section.id }}"
  data-product-id="{{ product.id }}"
  style="display: none;"
>
  <h3 class="review-photo-wall__title">Customer Photos</h3>
  <div class="review-photo-wall__grid" id="ReviewPhotoGrid-{{ section.id }}"></div>
</div>

<script>
(function() {
  var container = document.getElementById('ReviewPhotoWall-{{ section.id }}');
  if (!container) return;
  var grid = document.getElementById('ReviewPhotoGrid-{{ section.id }}');
  var productId = container.dataset.productId;
  if (!productId) return;

  function loadReviewPhotos() {
    var jdgmReviews = window.jdgmReviews || window.__jdgmReviews || [];
    if (!jdgmReviews.length) {
      var scriptEl = document.querySelector('script[data-jdgm-review-data]');
      if (scriptEl) {
        try { jdgmReviews = JSON.parse(scriptEl.textContent); } catch(e) {}
      }
    }

    var photos = [];
    if (Array.isArray(jdgmReviews)) {
      jdgmReviews.forEach(function(r) {
        if (r.pictures && r.pictures.length) {
          r.pictures.forEach(function(pic) {
            photos.push({
              src: pic.url || pic,
              reviewUrl: r.review_url || '#',
              author: r.reviewer?.name || r.author || '',
              title: r.title || ''
            });
          });
        }
      });
    }

    if (photos.length === 0) return;
    container.style.display = 'block';

    var html = '';
    photos.slice(0, 12).forEach(function(p) {
      var src = p.src.replace(/^\/\//, 'https://');
      html +=
        '<a href="' + p.reviewUrl + '" class="review-photo-wall__item" target="_blank" rel="noopener">' +
        '<img src="' + src + '" alt="Review by ' + p.author + '" loading="lazy" />' +
        '</a>';
    });
    grid.innerHTML = html;
  }

  if (window.jdgm && window.jdgm.reviews) {
    loadReviewPhotos();
  } else {
    document.addEventListener('jdgm.done', loadReviewPhotos);
    document.addEventListener('jdgm.reviews_loaded', loadReviewPhotos);
    setTimeout(loadReviewPhotos, 3000);
  }
})();
</script>

<style>
  .review-photo-wall {
    margin: 20px 0;
  }
  .review-photo-wall__title {
    font-size: 16px;
    font-weight: 600;
    margin: 0 0 12px;
    color: rgb(var(--color-foreground));
  }
  .review-photo-wall__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 8px;
  }
  @media screen and (max-width: 749px) {
    .review-photo-wall__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 6px;
    }
  }
  .review-photo-wall__item {
    aspect-ratio: 1;
    overflow: hidden;
    border-radius: 6px;
    display: block;
    border: 1px solid rgb(var(--color-foreground), 0.08);
  }
  .review-photo-wall__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.2s ease;
  }
  .review-photo-wall__item:hover img {
    transform: scale(1.05);
  }
</style>
