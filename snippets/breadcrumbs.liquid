<nav class="breadcrumbs" role="navigation" aria-label="breadcrumbs">
  <ol class="breadcrumbs__list">
    <li class="breadcrumbs__item">
      <a class="breadcrumbs__link" href="/">Home</a>
    </li>
    {%- if request.page_type == 'product' -%}
      {%- if collection and collection.url -%}
        <li class="breadcrumbs__item">
          <span aria-hidden="true" class="breadcrumbs__separator">&rsaquo;</span>
          <a class="breadcrumbs__link" href="{{ collection.url }}">{{ collection.title | escape }}</a>
        </li>
      {%- endif -%}
      <li class="breadcrumbs__item">
        <span aria-hidden="true" class="breadcrumbs__separator">&rsaquo;</span>
        <span class="breadcrumbs__current" aria-current="page">{{ product.title | escape }}</span>
      </li>
    {%- elsif request.page_type == 'collection' and collection -%}
      <li class="breadcrumbs__item">
        <span aria-hidden="true" class="breadcrumbs__separator">&rsaquo;</span>
        <span class="breadcrumbs__current" aria-current="page">{{ collection.title | escape }}</span>
      </li>
    {%- elsif request.page_type == 'article' and article -%}
      <li class="breadcrumbs__item">
        <span aria-hidden="true" class="breadcrumbs__separator">&rsaquo;</span>
        <a class="breadcrumbs__link" href="{{ blog.url }}">{{ blog.title | escape }}</a>
      </li>
      <li class="breadcrumbs__item">
        <span aria-hidden="true" class="breadcrumbs__separator">&rsaquo;</span>
        <span class="breadcrumbs__current" aria-current="page">{{ article.title | escape }}</span>
      </li>
    {%- elsif request.page_type == 'blog' and blog -%}
      <li class="breadcrumbs__item">
        <span aria-hidden="true" class="breadcrumbs__separator">&rsaquo;</span>
        <span class="breadcrumbs__current" aria-current="page">{{ blog.title | escape }}</span>
      </li>
    {%- elsif request.page_type == 'page' and page -%}
      <li class="breadcrumbs__item">
        <span aria-hidden="true" class="breadcrumbs__separator">&rsaquo;</span>
        <span class="breadcrumbs__current" aria-current="page">{{ page.title | escape }}</span>
      </li>
    {%- endif -%}
  </ol>

  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": "{{ shop.url }}"
        }
        {%- if request.page_type == 'product' -%}
          {%- if collection and collection.url -%}
          ,{
            "@type": "ListItem",
            "position": 2,
            "name": "{{ collection.title | escape }}",
            "item": "{{ shop.url }}{{ collection.url }}"
          },{
            "@type": "ListItem",
            "position": 3,
            "name": "{{ product.title | escape }}",
            "item": "{{ shop.url }}{{ product.url }}"
          }
          {%- else -%}
          ,{
            "@type": "ListItem",
            "position": 2,
            "name": "{{ product.title | escape }}",
            "item": "{{ shop.url }}{{ product.url }}"
          }
          {%- endif -%}
        {%- elsif request.page_type == 'collection' -%}
          ,{
            "@type": "ListItem",
            "position": 2,
            "name": "{{ collection.title | escape }}",
            "item": "{{ shop.url }}{{ collection.url }}"
          }
        {%- elsif request.page_type == 'article' -%}
          ,{
            "@type": "ListItem",
            "position": 2,
            "name": "{{ blog.title | escape }}",
            "item": "{{ shop.url }}{{ blog.url }}"
          },{
            "@type": "ListItem",
            "position": 3,
            "name": "{{ article.title | escape }}",
            "item": "{{ shop.url }}{{ article.url }}"
          }
        {%- elsif request.page_type == 'page' -%}
          ,{
            "@type": "ListItem",
            "position": 2,
            "name": "{{ page.title | escape }}",
            "item": "{{ shop.url }}{{ page.url }}"
          }
        {%- endif -%}
      ]
    }
  </script>
</nav>

<style>
  .breadcrumbs {
    padding: 1.5rem 1.5rem 0;
    font-size: 1.2rem;
    letter-spacing: 0.04rem;
    line-height: 1.8;
    color: rgba(var(--color-foreground), 0.7);
  }
  .breadcrumbs__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
  }
  .breadcrumbs__item {
    display: flex;
    align-items: center;
  }
  .breadcrumbs__separator {
    margin: 0 0.5rem;
  }
  .breadcrumbs__link {
    color: rgba(var(--color-foreground), 0.7);
    text-decoration: none;
  }
  .breadcrumbs__link:hover {
    text-decoration: underline;
    color: rgb(var(--color-foreground));
  }
  .breadcrumbs__current {
    color: rgb(var(--color-foreground));
  }

  @media screen and (min-width: 750px) {
    .breadcrumbs {
      padding: 1.5rem 5rem 0;
    }
  }
</style>
