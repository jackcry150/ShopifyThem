{%- comment -%}
  The Shopify menu entries are labels only and currently point at /collections.
  Route those labels to the real singular collection handles.
{%- endcomment -%}
{%- assign category_url = link.url -%}
{%- assign category_menu_handle = link.handle | downcase -%}
{%- if category_menu_handle == 'tops' -%}
  {%- assign category_url = routes.collections_url | append: '/top?view=doll-category' -%}
{%- elsif category_menu_handle == 'bottoms' -%}
  {%- assign category_url = routes.collections_url | append: '/bottom?view=doll-category' -%}
{%- endif -%}
{{- category_url -}}
